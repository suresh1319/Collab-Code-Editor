# ============================================
# Server Configuration
# ============================================

# Port for the backend server (Socket.IO + Yjs WebSocket)
PORT=3001

# Allowed origin for CORS.
# For local development, use http://localhost:3000.
# For production deployment (server-only.js), use your Vercel app URL.
CLIENT_ORIGIN=http://localhost:3000

# ============================================
# Client Configuration
# (must be prefixed with REACT_APP_)
# ============================================

# Backend URL used by the React frontend for Socket.IO and Yjs connections
REACT_APP_BACKEND_URL=http://localhost:3001
